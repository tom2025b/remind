#!/usr/bin/env bash
# ============================================================
# sched — friendly desktop reminder scheduler using 'at'
# Schedules both a desktop popup AND an email at the same time.
# Jobs survive terminal close; atd re-queues them across reboots.
# Usage: remind "msg" <minutes|time>  |  remind list  |  remind clear
#        remind "msg" <minutes> repeat  →  repeats every N minutes forever
# ============================================================

set -euo pipefail  # exit on error, undefined var, or pipe failure

# Capture display/session env vars now so the at job can reach the desktop.
# All three are required: DISPLAY (which screen), XAUTHORITY (X11 auth cookie),
# and DBUS_SESSION_BUS_ADDRESS (message bus that notify-send talks to).
DISPLAY_VAR="${DISPLAY:-:0}"
XAUTH_VAR="${XAUTHORITY:-$HOME/.Xauthority}"
DBUS_VAR="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}"

# ------------------------------------------------------------------
# usage() — shown when args are missing or wrong
# ------------------------------------------------------------------
usage() {
    cat <<'EOF'

  📅  sched — schedule desktop reminders

  Commands:
    sched "message" 25              → remind in 25 minutes
    sched "message" 14:30          → remind at 2:30 PM today
    sched "message" "Monday 09:00" → remind next Monday at 9 AM
    sched "message" 25 repeat       → remind every 25 minutes (repeats forever)
    remind list                     → show pending reminders (all at-jobs)
    remind clear                    → cancel ALL pending at-jobs for your user

EOF
    exit 1
}

[[ $# -eq 0 ]] && usage

# ------------------------------------------------------------------
# Subcommands: list and clear
# ------------------------------------------------------------------
case "$1" in

    list)
        while true; do
            echo ""
            tmpfile=$(mktemp)
            mapfile="${tmpfile}.map"
            atq > "$tmpfile"
            count=$(wc -l < "$tmpfile")

            if [[ "$count" -eq 0 ]]; then
                echo "  ✅  No reminders scheduled."
                echo ""
                rm -f "$tmpfile" "$mapfile"
                exit 0
            fi

            echo "  📋  Pending reminders (${count} total):"
            echo ""

            idx=1
            while read -r line; do
                job_id=$(echo "$line" | awk '{print $1}')
                job_time=$(echo "$line" | awk '{print $2, $3, $4, $5}')

                job_script=$(at -c "$job_id" 2>/dev/null || true)
                raw_msg=$(echo "$job_script" | grep '^SCHED_MSG=' | head -1 | cut -d= -f2- || true)
                display_msg=$(echo "$raw_msg" | sed 's/\\//g')
                requeue_line=$(echo "$job_script" | grep '/bin/cat.*remind/repeat-' | head -1 || true)

                if [[ -n "$requeue_line" ]]; then
                    interval=$(echo "$requeue_line" | grep -oP 'now \+ \K[0-9]+' || true)
                    payload=$(echo "$requeue_line" | sed 's|.*/bin/cat "\([^"]*\)".*|\1|')
                    echo "    [$idx]  🔁  Job #${job_id} — ${job_time} — repeating every ${interval} min"
                    [[ -n "$display_msg" ]] && echo "         \"${display_msg}\""
                    echo "${idx}=${job_id}=${payload}" >> "$mapfile"
                else
                    echo "    [$idx]  🔔  Job #${job_id} — ${job_time}"
                    [[ -n "$display_msg" ]] && echo "         \"${display_msg}\""
                    echo "${idx}=${job_id}=" >> "$mapfile"
                fi
                idx=$(( idx + 1 ))
            done < "$tmpfile"

            echo ""
            echo "    [0]  Exit"
            echo ""
            printf "  Cancel which reminder? > "
            read -r choice

            # 0 or empty = exit
            if [[ -z "$choice" || "$choice" == "0" ]]; then
                echo ""
                rm -f "$tmpfile" "$mapfile"
                exit 0
            fi

            if [[ ! "$choice" =~ ^[0-9]+$ ]]; then
                echo "  ❌  Please enter a number."
                rm -f "$tmpfile" "$mapfile"
                continue
            fi

            map_line=$(awk -F= -v idx="$choice" '$1 == idx { print }' "$mapfile" 2>/dev/null)
            real_id=$(echo "$map_line" | cut -d= -f2)
            payload_file=$(echo "$map_line" | cut -d= -f3-)

            if [[ -z "$real_id" ]]; then
                echo "  ❌  \"$choice\" isn't in the list."
            else
                if ! atrm "$real_id" 2>/dev/null; then
                    echo "  ⚠️   Job ${real_id} could not be removed (already expired?)."
                else
                    if [[ -n "$payload_file" && -f "$payload_file" ]]; then
                        rm -f "$payload_file"
                        echo "  🗑️   Repeating reminder #${choice} cancelled."
                    else
                        echo "  🗑️   Reminder #${choice} cancelled."
                    fi
                fi
            fi

            rm -f "$tmpfile" "$mapfile"
            # loop: redisplay updated list
        done
        exit 0
        ;;

    clear)
        echo ""
        ids=$(atq | awk '{print $1}')

        if [[ -z "$ids" ]]; then
            echo "  ✅  No reminders to clear."
        else
            # || true prevents set -e from aborting if any job already expired mid-clear
            echo "$ids" | xargs -r atrm 2>/dev/null || true
            count=$(echo "$ids" | wc -l)
            echo "  🗑️   Cleared ${count} reminder(s)."
            echo "  ⚠️   Note: clears ALL your at-jobs, not just remind reminders."
        fi

        # Also remove any persistent repeat payload scripts — these drive the repeat chain
        # and must be deleted to fully stop a repeating reminder.
        payload_dir="$HOME/.local/share/remind"
        if compgen -G "${payload_dir}/repeat-*.sh" > /dev/null 2>&1; then
            rm -f "${payload_dir}"/repeat-*.sh
            echo "  🗑️   Cleared repeat payload scripts."
        fi

        echo ""
        exit 0
        ;;
esac

# ------------------------------------------------------------------
# Schedule a new reminder — requires exactly 2 arguments
# ------------------------------------------------------------------
[[ $# -lt 2 ]] && usage

# Strip newlines from the message — a newline inside the Subject: header
# would corrupt the email (RFC 2822 header injection).
MESSAGE="${1//$'\n'/ }"
WHEN="$2"

# Catch swapped args: remind "msg" repeat 30 → should be remind "msg" 30 repeat
if [[ "$WHEN" == "repeat" && "${3:-}" =~ ^[0-9]+$ ]]; then
    echo ""
    echo "  ❌  Wrong order — minutes comes before 'repeat':"
    echo "     remind \"${MESSAGE}\" ${3} repeat"
    echo ""
    exit 1
fi

# Optional 3rd argument: "repeat" — re-schedules itself each time it fires.
# Only supported with integer (minute) intervals since we need a fixed delay
# to self-reschedule inside the at job.
REPEAT=false
if [[ "${3:-}" == "repeat" ]]; then
    if [[ ! "$WHEN" =~ ^[0-9]+$ ]]; then
        echo ""
        echo "  ❌  'repeat' only works with a minute count (e.g. sched \"msg\" 25 repeat)"
        echo "     Clock times like 14:30 can't self-repeat reliably."
        echo ""
        exit 1
    fi
    REPEAT=true
fi

# Pure integer → minutes from now; anything else passes straight to 'at'
if [[ "$WHEN" =~ ^[0-9]+$ ]]; then
    AT_TIME="now + ${WHEN} minutes"
    HUMAN_TIME="in ${WHEN} minute(s)"
else
    AT_TIME="$WHEN"       # e.g. "14:30" or "Monday 09:00"
    HUMAN_TIME="at $WHEN"
fi

# Warn early if DBUS is missing — notify-send will silently fail without it
if [[ -z "$DBUS_VAR" ]]; then
    echo "  ⚠️   DBUS_SESSION_BUS_ADDRESS not set — desktop popup may not appear."
fi

# Shell-quote MESSAGE so it's safe to embed in the job script.
# printf '%q' produces a form the shell can re-read without injection risks,
# handling double quotes, dollar signs, backticks, and spaces correctly.
SAFE_MSG=$(printf '%q' "$MESSAGE")

# Build and submit the job.
#
# ONE-SHOT MODE: pipe the job script directly to 'at' via stdin.
#
# REPEAT MODE: write a persistent payload script to ~/.local/share/remind/
# and schedule it with 'at -f <file>'. The payload script re-submits itself
# via 'at -f' each time it fires — no subprocess call back to remind needed.
# This is robust because: no set -euo pipefail inside the payload, no PATH
# issues finding remind, and the file survives across firings.
# Stop with: remind clear  (removes at jobs AND the payload file).

if $REPEAT; then
    # Create the directory for persistent repeat payload scripts
    PAYLOAD_DIR="$HOME/.local/share/remind"
    mkdir -p "$PAYLOAD_DIR"
    # mktemp guarantees a unique filename; safer than $RANDOM concatenation
    PAYLOAD_FILE=$(mktemp "${PAYLOAD_DIR}/repeat-XXXXXX.sh")

    # Write the payload script. All variables ($DISPLAY_VAR, $SAFE_MSG, etc.)
    # are expanded NOW at schedule time and baked into the file.
    # The last line re-submits this same file to 'at' using its full path,
    # which is also baked in — no PATH lookup needed at fire time.
    cat > "$PAYLOAD_FILE" <<EOF
export DISPLAY="${DISPLAY_VAR}"
export XAUTHORITY="${XAUTH_VAR}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_VAR}"
SCHED_MSG=${SAFE_MSG}

# Re-submit FIRST via stdin pipe — more reliable than at -f when called from inside an at job.
/bin/cat "${PAYLOAD_FILE}" | /usr/bin/at now + ${WHEN} minutes 2>/dev/null || \
    echo "remind repeat failed to re-queue at \$(date)" >> "${PAYLOAD_FILE}.err"

# Notifications are non-critical — || true ensures they never kill the script.
/usr/bin/notify-send --urgency=normal --icon=dialog-information "🔁 Reminder (repeating)" "\$SCHED_MSG" 2>/dev/null || true

# Note: \\ in this heredoc produces a single \ in the written file (line continuation).
# Do NOT change \\ to \ here — the heredoc would swallow it and break the printf.
printf 'To: thomaslane2025@gmail.com\nSubject: Reminder (repeating): %s\nDate: %s\n\nReminder: %s\n\nThis is a repeating reminder (every ${WHEN} min). To stop: remind clear\n' \\
    "\$SCHED_MSG" "\$(date -R)" "\$SCHED_MSG" \\
    | /usr/bin/msmtp -a gmail thomaslane2025@gmail.com 2>/dev/null || true
EOF

    # Schedule the first firing using at -f (reads from the payload file)
    # $AT_TIME is unquoted so 'at' receives "now + N minutes" as separate words
    if ! AT_OUTPUT=$(/usr/bin/at -f "$PAYLOAD_FILE" $AT_TIME 2>&1); then
        echo ""
        echo "  ❌  Failed to schedule reminder:"
        echo "     $AT_OUTPUT" >&2
        rm -f "$PAYLOAD_FILE"
        exit 1
    fi
else
    # One-shot mode: build the job inline and pipe to at via stdin
    JOB=$(cat <<EOF
export DISPLAY="${DISPLAY_VAR}"
export XAUTHORITY="${XAUTH_VAR}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_VAR}"
SCHED_MSG=${SAFE_MSG}

# Use full path so notify-send is found in at's minimal PATH
/usr/bin/notify-send --urgency=normal --icon=dialog-information "Reminder" "\$SCHED_MSG"

# Email via msmtp — To: and Date: headers required for RFC 2822 compliance
printf 'To: thomaslane2025@gmail.com\nSubject: Reminder: %s\nDate: %s\n\nReminder: %s\n\nScheduled with remind.\n' \
    "\$SCHED_MSG" "\$(date -R)" "\$SCHED_MSG" \
    | /usr/bin/msmtp -a gmail thomaslane2025@gmail.com
EOF
)
    # Submit the job. 'if !' prevents set -e from firing before we can show the error.
    # 2>&1 captures at's stderr (errors AND the "job N at DATE" confirmation).
    if ! AT_OUTPUT=$(echo "$JOB" | /usr/bin/at $AT_TIME 2>&1); then
        echo ""
        echo "  ❌  Failed to schedule reminder:"
        echo "     $AT_OUTPUT" >&2
        exit 1
    fi
fi

echo ""
if $REPEAT; then
    echo "  ✅  Repeating reminder scheduled every ${WHEN} minute(s):"
    echo "     \"${MESSAGE}\""
    echo "     (desktop popup + email — repeats forever)"
    echo "     To stop: remind clear  (removes at job + payload file)"
else
    echo "  ✅  Reminder scheduled ${HUMAN_TIME}:"
    echo "     \"${MESSAGE}\""
    echo "     (desktop popup + email)"
fi
echo ""

# ============================================================
# Learning Notes
# ============================================================
# at / atq / atrm  — one-shot scheduler daemon; jobs survive reboots
# notify-send      — sends a desktop popup via the notification daemon
# msmtp            — lightweight SMTP client; reads raw email from stdin
# printf '%q'      — shell-quotes a string so it survives re-evaluation;
#                    prevents injection via $(), backticks, or quotes in the msg
# set -euo pipefail — strict mode: abort on first error, undefined var, or pipe fail
# DISPLAY          — X11 screen address; must be exported for GUI tools in cron/at
# DBUS_SESSION_BUS_ADDRESS — message bus for notify-send; empty outside login session
# RFC 2822         — email format standard; requires To: Subject: Date: headers
# persistent payload  — repeat mode writes a shell script to ~/.local/share/remind/
#                    and schedules it with 'at -f'; the script re-submits itself
#                    each firing — no dependency on remind being on PATH in at context
# at -f <file>       — tells 'at' to read the job script from a file instead of stdin
# ============================================================
